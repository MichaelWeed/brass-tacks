#!/bin/bash

# Get the path to this executable inside the app bundle
# Info.plist specifies this script as the executable
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
# Resolve the project root relative to Info.plist inside BrassTacks.app/Contents/MacOS/BrassTacks
# Back up 3 levels: Contents/MacOS -> Contents -> BrassTacks.app -> launcher -> project_root
PROJECT_ROOT=""

# Check if a config file containing the repository path exists
if [ -f "$HOME/.config/brasstacks/repo_path" ]; then
    PROJECT_ROOT=$(cat "$HOME/.config/brasstacks/repo_path")
fi

# Fallback: Check standard locations or use bundle relative path
if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT" ]; then
    # Try relative path first (if run directly inside the repo)
    REL_PATH="$(cd "$SELF_DIR/../../../../" && pwd)"
    if [ -f "$REL_PATH/start.sh" ]; then
        PROJECT_ROOT="$REL_PATH"
    else
        # Try parent directory relative check
        REL_PATH="$(cd "$SELF_DIR/../../../../../" && pwd)"
        if [ -f "$REL_PATH/start.sh" ]; then
            PROJECT_ROOT="$REL_PATH"
        fi
    fi
fi

# If we still can't find it, show AppleScript error and exit
if [ -z "$PROJECT_ROOT" ] || [ ! -d "$PROJECT_ROOT" ]; then
    osascript -e "display dialog \"Brass Tacks Repository not found. Please run the root install.sh script to register the installation path.\" with title \"Brass Tacks Launcher\" buttons {\"OK\"} default button \"OK\" with icon caution"
    exit 1
fi

cd "$PROJECT_ROOT"

# Check if Podman or Docker is installed
if ! command -v podman &> /dev/null && ! command -v docker &> /dev/null; then
    # Neither is found. If Homebrew is not installed either, we show an error dialog since we can't auto-install
    if ! command -v brew &> /dev/null; then
        osascript -e "display dialog \"Neither Podman nor Docker was found. Please install a container runner (like Docker Desktop or Podman) to run Brass Tacks.\" with title \"Brass Tacks Launcher\" buttons {\"OK\"} default button \"OK\" with icon caution"
        exit 1
    fi
fi

# Launch start.sh in a new terminal window to display logs
osascript <<EOF
tell application "Terminal"
    do script "cd '$PROJECT_ROOT' && ./start.sh"
    activate
end tell
EOF

exit 0
