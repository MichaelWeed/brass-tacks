# TailorForge Environment Configuration
# Copy this file to backend/.env to configure backend service parameters

# Database Connection (Postgres)
DATABASE_URL=postgresql://tailorforge_admin:temp_password_change_me@localhost/tailorforge

# Vector Database Connection (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Parsing Service Connection (Docling)
PARSER_SERVICE_URL=http://localhost:8081

# JWT Secret signing key
SECRET_KEY=super-secret-dev-key

# Optional: Default Gemini API Key (User can override this dynamically in frontend Settings)
GEMINI_API_KEY=
